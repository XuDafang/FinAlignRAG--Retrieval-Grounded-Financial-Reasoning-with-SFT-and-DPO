# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/
.venv/
venv/
env/
.docx
# ML / training artifacts
outputs/dpo_adapter/*
!outputs/dpo_adapter/.gitkeep
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.msgpack
# SFT adapter tracked via Git LFS — un-ignore files in that directory
!outputs/sft_adapter/adapter_model.safetensors
!outputs/sft_adapter/training_args.bin

# Raw datasets — never track / push / clone .json data files
# (FinQA / ConvFinQA / EDGAR dumps live in data/*.json and are large).
# NOTE: this matches *.json ONLY — *.jsonl (predictions, sft/dpo splits) is
# NOT matched and remains trackable. To force-keep a specific json, add an
# explicit exception below, e.g.  !configs/schema.json
*.json
!outputs/sft_adapter/*.json

# FAISS indexes / processed artifacts
*.faiss
*.index
data/processed/*
data/sft/*
data/dpo/*
!data/processed/.gitkeep
!data/sft/.gitkeep
!data/dpo/.gitkeep

# Reports are generated, keep the dir only
reports/*
!reports/.gitkeep

# HuggingFace / model caches
.cache/
hf_cache/
.huggingface/

# Models — ignore ANY model (weights, tokenizers, checkpoints) in ANY location.
# Common local model/checkpoint directories
models/
pretrained/
pretrained_models/
saved_models/
model_cache/
checkpoints/
checkpoint-*/
**/checkpoint-*/
# Weight / serialized-model formats not already covered above
# (.gitignore has NO inline comments — keep notes on their own lines)
*.model
*.onnx
*.gguf
*.ggml
*.h5
*.pb
*.tflite
*.mlmodel
# TensorRT
*.engine
*.trt
*.plan
# PaddlePaddle / MXNet / Caffe / Torch-legacy
*.pdparams
*.params
*.caffemodel
*.t7
# sklearn / generic pickled artifacts
*.joblib
*.pkl
*.pickle

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Docx unpack scratch (from document analysis)
unpacked_arch/
unpacked_playbook/
